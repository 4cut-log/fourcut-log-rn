{
  "extends": "@react-native/typescript-config/tsconfig.json",
  "compilerOptions": {
    "jsx": "react",
    "baseUrl": "./src",
    "paths": {
      "@/*": ["*"],
      "@screens": ["screens"],
      "@screens/*": ["screens/*"],
      "@components": ["components/index"],
      "@constants/*": ["constants/*"],
      "@hooks/*": ["hooks/*"],
      "@type/*": ["types/*"],
      "@api/*": ["api/*"],
      "@images/*": ["assets/images/*"],
      "@css/*": ["assets/css/*"],
      "@utils/*": ["utils/*"]
    }
  }
}
